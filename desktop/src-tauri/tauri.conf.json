{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "danmaku-overlay",
  "version": "0.1.0",
  "identifier": "com.kolvid.danmaku-overlay",
  "build": {
    "beforeBuildCommand": {
      "cwd": "../../clients/web-overlay",
      "script": "npm run build:desktop"
    },
    "beforeDevCommand": {
      "cwd": "../../clients/web-overlay",
      "script": "npm run build:desktop",
      "wait": true
    },
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "彈幕 Overlay",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "fullscreen": false,
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:3999 ws://127.0.0.1:3999; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
