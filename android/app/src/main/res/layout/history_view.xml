<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD14141E"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/history_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/history_title"
            android:textColor="#B2B5BE"
            android:textSize="13sp" />

        <Button
            android:id="@+id/history_close_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/close_symbol"
            android:textSize="12sp"
            android:background="@android:color/transparent"
            android:textColor="#B2B5BE"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Scroll list -->
    <ScrollView
        android:id="@+id/history_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="350dp">

        <LinearLayout
            android:id="@+id/history_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
