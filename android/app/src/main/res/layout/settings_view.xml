<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE14141E"
    android:fillViewport="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/settings_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/appearance_settings_title"
                android:textColor="#B2B5BE"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settings_close_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="@string/close_symbol"
                android:textColor="#B2B5BE"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/nickname_settings"
            android:textColor="#E6EDF3"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/settings_nickname_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/nickname_hint"
            android:imeOptions="actionDone"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLength="6"
            android:singleLine="true"
            android:textColor="#E6EDF3"
            android:textColorHint="#8090A0" />

        <Button
            android:id="@+id/settings_nickname_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_nickname"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/settings_nickname_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:accessibilityLiveRegion="polite"
            android:textColor="#B2B5BE"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/ball_settings"
            android:textColor="#E6EDF3"
            android:textStyle="bold" />

        <Button
            android:id="@+id/settings_ball_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:text="@string/color"
            android:textSize="12sp" />

        <include
            android:id="@+id/settings_ball_color_picker"
            layout="@layout/color_picker_panel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/size"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_ball_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="32"
            android:max="96"
            android:progress="56" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opacity_minimum"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_ball_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:min="10"
            android:max="100"
            android:progress="90" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/barrage_settings"
            android:textColor="#E6EDF3"
            android:textStyle="bold" />

        <Button
            android:id="@+id/settings_dm_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:text="@string/color"
            android:textSize="12sp" />

        <include
            android:id="@+id/settings_dm_color_picker"
            layout="@layout/color_picker_panel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_size"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_dm_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="12"
            android:max="48"
            android:progress="20" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opacity_minimum"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_dm_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:min="10"
            android:max="100"
            android:progress="90" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/input_settings"
            android:textColor="#E6EDF3"
            android:textStyle="bold" />

        <Button
            android:id="@+id/settings_input_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:text="@string/color"
            android:textSize="12sp" />

        <include
            android:id="@+id/settings_input_color_picker"
            layout="@layout/color_picker_panel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_size"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_input_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="12"
            android:max="32"
            android:progress="16" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/background_opacity_minimum"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_input_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:min="10"
            android:max="100"
            android:progress="80" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/panel_width"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_panel_width"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="280"
            android:max="800"
            android:progress="320" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/panel_height_auto"
            android:textColor="#80E6EDF3"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/settings_panel_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="800"
            android:progress="0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/settings_reset_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="#22FFFFFF"
                android:minHeight="0dp"
                android:padding="8dp"
                android:text="@string/restore_defaults"
                android:textColor="#E6EDF3"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settings_help_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="#22FFFFFF"
                android:minHeight="0dp"
                android:padding="8dp"
                android:text="@string/help"
                android:textColor="#E6EDF3"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
