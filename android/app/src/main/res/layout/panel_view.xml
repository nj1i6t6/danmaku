<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC14141E"
    android:padding="12dp"
    android:layout_margin="8dp">

    <!-- Header: room label + buttons -->
    <LinearLayout
        android:id="@+id/panel_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/panel_room_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:minHeight="48dp"
            android:text="@string/default_room_loading"
            android:textAllCaps="false"
            android:textColor="#B2B5BE"
            android:textSize="13sp" />

        <Button
            android:id="@+id/panel_history_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/history_description"
            android:text="@string/history_symbol"
            android:textSize="12sp"
            android:background="@android:color/transparent"
            android:textColor="#B2B5BE"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/panel_settings_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/settings_description"
            android:text="@string/settings_symbol"
            android:textSize="12sp"
            android:background="@android:color/transparent"
            android:textColor="#B2B5BE"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Input + send -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/panel_msg_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/message_hint"
            android:textColorHint="#666666"
            android:textColor="#E6EDF3"
            android:textSize="14sp"
            android:background="@drawable/panel_input_bg"
            android:padding="8dp"
            android:maxLength="100"
            android:importantForAutofill="no"
            android:inputType="text" />

        <Button
            android:id="@+id/panel_send_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/send_ready"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#CC58A6FF"
            android:layout_marginStart="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />
    </LinearLayout>
    <TextView
        android:id="@+id/panel_send_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#B2B5BE"
        android:textSize="12sp" />
    <Button
        android:id="@+id/panel_retry_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/retry_queued_message"
        android:visibility="gone" />
</LinearLayout>
