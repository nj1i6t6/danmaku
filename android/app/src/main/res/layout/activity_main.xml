<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A2E"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textSize="28sp"
        android:textColor="#E6EDF3"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/permission_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/overlay_permission_required"
        android:textSize="16sp"
        android:textColor="#B2B5BE"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_grant_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/grant_overlay_permission"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_start_service"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_overlay"
        android:enabled="false"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_reset_position"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reset_ball_position"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_reset_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reset_default_settings" />

</LinearLayout>
