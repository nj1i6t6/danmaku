# Copy to a private environment file and adjust for your deployment.
NODE_ENV=production
PORT=3999
DB_PATH=/var/lib/stock-danmaku/reports.db

# Enable only when the immediate reverse proxy is trusted and loopback-local.
TRUST_CLOUDFLARE_PROXY=0
MAX_CONNECTIONS_PER_IP=100

# Development browser origins are disabled by default. Never enable this on production.
ALLOW_DEV_ORIGINS=0

# Production HTTPS policy. PUBLIC_ORIGIN must be an HTTPS origin only.
ENFORCE_HTTPS=0
PUBLIC_ORIGIN=https://example.com

# Optional comma-separated browser extension origins.
# Every entry must exactly match chrome-extension://[a-p]{32}; invalid entries stop startup.
# Extension IDs are public identifiers, but deployment-specific values do not belong in this example.
EXTENSION_ORIGINS=
